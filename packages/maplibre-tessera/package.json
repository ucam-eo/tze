{
  "name": "@ucam-eo/maplibre-tessera",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run --passWithNoTests",
    "check": "tsc --noEmit",
    "docs": "typedoc --plugin typedoc-plugin-markdown",
    "docs:html": "typedoc"
  },
  "peerDependencies": {
    "maplibre-gl": ">=4.0.0 || >=5.0.0"
  },
  "dependencies": {
    "@ucam-eo/tessera": "workspace:*",
    "zarrita": "^0.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "maplibre-gl": "^5.20.1",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
